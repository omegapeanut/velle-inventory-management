rules_version = '2';

// Velle Inventory Management — Firestore security rules.
// Paste these into Firebase Console → Firestore Database → Rules → Publish.
// Requires Anonymous sign-in to be enabled (Authentication → Sign-in method → Anonymous).
service cloud.firestore {
  match /databases/{database}/documents {

    // All app data lives under appState/<collection>. Allow only signed-in
    // (anonymous) app sessions, and restrict payload to a single "items" array.
    match /appState/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.data.keys().hasOnly(['items'])
                   && request.resource.data.items is list;
    }

    // Everything else is denied.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
