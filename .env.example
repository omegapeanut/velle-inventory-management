# Copy this file to ".env" and fill in your own values. ".env" is gitignored.

# --- Firebase (client config) ---
# Firebase Console → Project settings (gear) → Your apps → SDK setup and configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Cloudinary (unsigned browser uploads) ---
# Cloudinary dashboard → Cloud name; and an Unsigned upload preset name
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
